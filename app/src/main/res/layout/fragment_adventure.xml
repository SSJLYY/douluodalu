<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true"
    android:paddingTop="8dp"
    android:paddingBottom="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- 当前地图信息 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🗺️ 当前地图"
                android:textColor="@color/accent"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_current_map"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_gold"
                android:textSize="16sp"
                android:text="圣魂村"
                android:layout_marginTop="4dp" />

            <TextView
                android:id="@+id/tv_map_floor"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:text="第 1 层"
                android:layout_marginTop="2dp" />


            <TextView
                android:id="@+id/tv_map_effect"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/rarity_epic"
                android:textSize="11sp"
                android:text=""
                android:layout_marginTop="2dp"
                android:visibility="gone" />

            <Button
                android:id="@+id/btn_auto_advance"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="4dp"
                android:backgroundTint="@color/btn_hunt"
                android:foreground="?attr/selectableItemBackground"
                android:stateListAnimator="@null"
                android:minHeight="44dp"
                android:text="🗺️ 自动跳图: 开"
                android:textColor="@android:color/white"
                android:textSize="13sp" />

            <Button
                android:id="@+id/btn_reset_map"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="8dp"
                android:backgroundTint="@color/btn_normal"
                android:foreground="?attr/selectableItemBackground"
                android:stateListAnimator="@null"
                android:minHeight="44dp"
                android:text="🔄 重置地图（回第1层+满血）"
                android:textColor="@android:color/white"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- 地图列表 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="12dp"
            android:layout_marginTop="10dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🌍 地图"
                android:textColor="@color/accent"
                android:textSize="15sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/map_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="6dp" />
        </LinearLayout>

        <!-- 杀戮之都 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="12dp"
            android:layout_marginTop="10dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💀 杀戮之都"
                android:textColor="@color/btn_prestige"
                android:textSize="15sp"
                android:textStyle="bold" />

            <!-- 段位/进度 -->
            <TextView
                android:id="@+id/tv_tower_segment"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_gold"
                android:textSize="13sp"
                android:text="段位：修罗场 (入门)"
                android:layout_marginTop="4dp" />

            <TextView
                android:id="@+id/tv_tower_info"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:text="第 0 层 / 100"
                android:textStyle="bold"
                android:layout_marginTop="2dp" />

            <TextView
                android:id="@+id/tv_tower_power"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:text="下一层推荐战力：1"
                android:layout_marginTop="2dp" />

            <!-- 杀气货币 -->
            <TextView
                android:id="@+id/tv_killing_intent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/rarity_mythic"
                android:textSize="14sp"
                android:text="⚔️ 杀气：0"
                android:textStyle="bold"
                android:layout_marginTop="4dp" />

            <!-- 塔内HP条 -->
            <LinearLayout
                android:id="@+id/tower_hp_bar_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="6dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="塔内HP："
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tv_tower_hp"
                    android:layout_width="0dp"
                    android:layout_height="18dp"
                    android:layout_weight="1"
                    android:background="@drawable/progress_hp_bg"
                    android:gravity="center"
                    android:text="100%"
                    android:textColor="@android:color/white"
                    android:textSize="11sp" />
            </LinearLayout>

            <!-- 怪物预览 -->
            <TextView
                android:id="@+id/tv_tower_monster"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/rarity_epic"
                android:textSize="12sp"
                android:text=""
                android:layout_marginTop="4dp"
                android:visibility="gone" />

            <!-- 进入按钮 -->
            <Button
                android:id="@+id/btn_tower_enter"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="8dp"
                android:backgroundTint="@color/btn_normal"
                android:foreground="?attr/selectableItemBackground"
                android:stateListAnimator="@null"
                android:minHeight="44dp"
                android:text="🚪 进入杀戮之都"
                android:textColor="@android:color/white"
                android:textSize="14sp" />

            <!-- 挑战按钮 -->
            <Button
                android:id="@+id/btn_tower_challenge"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="4dp"
                android:backgroundTint="@color/btn_prestige"
                android:foreground="?attr/selectableItemBackground"
                android:stateListAnimator="@null"
                android:visibility="gone"
                android:text="⚔️ 挑战下一层"
                android:textColor="@android:color/white"
                android:textSize="14sp" />

            <!-- 扫荡+退出行 -->
            <LinearLayout
                android:id="@+id/tower_action_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="4dp"
                android:visibility="gone">

                <Button
                    android:id="@+id/btn_tower_sweep"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:backgroundTint="@color/btn_hunt"
                    android:foreground="?attr/selectableItemBackground"
                    android:stateListAnimator="@null"
                    android:text="⚡ 扫荡"
                    android:textColor="@android:color/white"
                    android:textSize="13sp" />

                <Button
                    android:id="@+id/btn_tower_exit"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:backgroundTint="@color/btn_disabled"
                    android:foreground="?attr/selectableItemBackground"
                    android:stateListAnimator="@null"
                    android:text="🚪 退出"
                    android:textColor="@android:color/white"
                    android:textSize="13sp" />
            </LinearLayout>

            <Button
                android:id="@+id/btn_tower_reset"
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:layout_marginTop="4dp"
                android:backgroundTint="@color/btn_disabled"
                android:foreground="?attr/selectableItemBackground"
                android:stateListAnimator="@null"
                android:text="🔄 重置塔进度"
                android:textColor="@android:color/white"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- 杀气兑换商店 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg_epic"
            android:padding="12dp"
            android:layout_marginTop="10dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚔️ 杀气兑换"
                android:textColor="@color/rarity_mythic"
                android:textSize="15sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/tower_shop_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="6dp" />
        </LinearLayout>

        <!-- 每日副本 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg_gold"
            android:padding="12dp"
            android:layout_marginTop="10dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💀 每日副本"
                android:textColor="@color/rarity_legendary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_dungeon_info"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:text="转生1次后解锁"
                android:layout_marginTop="4dp" />

            <TextView
                android:id="@+id/tv_dungeon_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:text=""
                android:layout_marginTop="2dp" />

            <Button
                android:id="@+id/btn_dungeon"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="6dp"
                android:backgroundTint="@color/btn_breakthrough"
                android:foreground="?attr/selectableItemBackground"
                android:stateListAnimator="@null"
                android:text="💀 挑战每日副本"
                android:textColor="@android:color/white"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- 成就列表 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="12dp"
            android:layout_marginTop="10dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🏆 成就"
                android:textColor="@color/accent"
                android:textSize="15sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/achievement_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="6dp" />
        </LinearLayout>

        <!-- 怪物图鉴 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg_epic"
            android:padding="12dp"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="10dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📖 怪物图鉴"
                android:textColor="@color/rarity_epic"
                android:textSize="15sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/codex_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="6dp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
