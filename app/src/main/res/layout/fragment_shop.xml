<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true"
    android:paddingTop="8dp"
    android:paddingBottom="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- 商店说明 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🏪 商店"
                android:textColor="@color/accent"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_shop_gold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_gold"
                android:textSize="14sp"
                android:text="金魂币: 0"
                android:layout_marginTop="4dp" />

            <TextView
                android:id="@+id/tv_shop_boss_coin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/rarity_epic"
                android:textSize="14sp"
                android:text="Boss币: 0"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- ===== 金币消耗 ===== -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="💰 金币消耗"
            android:textColor="@color/text_gold"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_marginTop="14dp"
            android:layout_marginBottom="2dp" />

        <!-- 功能1: 背包扩容 -->
        <LinearLayout
            android:id="@+id/shop_item_auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/card_bg"
            android:padding="12dp"
            android:layout_marginTop="6dp"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📦 背包扩容"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_shop_auto_desc"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:text="扩充背包容量"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tv_shop_auto_cost"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_gold"
                android:textSize="13sp"
                android:text="2000💰" />
        </LinearLayout>

        <!-- 功能3: 金币魂核抽卡 -->
        <LinearLayout
            android:id="@+id/shop_item_soulcore"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/card_bg"
            android:padding="12dp"
            android:layout_marginTop="6dp"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💠 魂核抽卡"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_shop_soulcore_desc"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:text="花费金币随机抽取魂核"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tv_shop_soulcore_cost"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_gold"
                android:textSize="13sp"
                android:text="50000💰" />
        </LinearLayout>

        <!-- 功能4: 限时商店刷新 -->
        <LinearLayout
            android:id="@+id/shop_item_refresh"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/card_bg"
            android:padding="12dp"
            android:layout_marginTop="6dp"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔄 限时刷新"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_shop_refresh_desc"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:text="花费金币立即刷新限时珍品"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tv_shop_refresh_cost"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_gold"
                android:textSize="13sp"
                android:text="20000💰" />
        </LinearLayout>

        <!-- ===== 限时珍品 ===== -->
        <LinearLayout
            android:id="@+id/limited_shop_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="12dp"
            android:layout_marginTop="14dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="⏳ 限时珍品"
                    android:textColor="@color/rarity_uncommon"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_limited_timer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/rarity_mythic"
                    android:textSize="13sp"
                    android:text="10:00" />
            </LinearLayout>

            <TextView
                android:id="@+id/tv_limited_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:text="金魂币购买基础魂环魂骨，每10分钟自动刷新"
                android:layout_marginTop="2dp"
                android:layout_marginBottom="4dp" />

            <LinearLayout
                android:id="@+id/limited_shop_items"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </LinearLayout>

        <!-- ===== Boss商店 ===== -->
        <LinearLayout
            android:id="@+id/boss_shop_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg_epic"
            android:padding="12dp"
            android:layout_marginTop="14dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💠 Boss商店"
                android:textColor="@color/rarity_epic"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="通过战斗获得Boss币，购买稀有物品"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:layout_marginTop="2dp"
                android:layout_marginBottom="8dp" />

            <!-- 魂核抽取 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/card_bg"
                android:padding="10dp"
                android:layout_marginTop="4dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="💠 魂核抽取"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_boss_gacha_cost"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:text="50 Boss币" />
                </LinearLayout>

                <Button
                    android:id="@+id/btn_boss_gacha"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:backgroundTint="@color/btn_hunt"
                    android:foreground="?attr/selectableItemBackground"
                    android:stateListAnimator="@null"
                    android:minHeight="44dp"
                    android:text="抽 取"
                    android:textColor="@android:color/white"
                    android:textSize="13sp"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp" />

                <Button
                    android:id="@+id/btn_boss_gacha_detail"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:backgroundTint="@color/text_secondary"
                    android:foreground="?attr/selectableItemBackground"
                    android:stateListAnimator="@null"
                    android:minHeight="44dp"
                    android:text="详 情"
                    android:textColor="@android:color/white"
                    android:textSize="12sp"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:layout_marginStart="4dp" />
            </LinearLayout>

            <!-- 魂力结晶 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/card_bg"
                android:padding="10dp"
                android:layout_marginTop="4dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="💎 魂力结晶"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_boss_crystal_cost"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:text="20 Boss币" />
                </LinearLayout>

                <Button
                    android:id="@+id/btn_boss_crystal"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:backgroundTint="@color/btn_normal"
                    android:foreground="?attr/selectableItemBackground"
                    android:stateListAnimator="@null"
                    android:minHeight="44dp"
                    android:text="+500魂力"
                    android:textColor="@android:color/white"
                    android:textSize="13sp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp" />
            </LinearLayout>

            <!-- 阶梯魂环商品（动态构建） -->
            <LinearLayout
                android:id="@+id/boss_ring_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="4dp" />

            <!-- 阶梯魂骨商品（动态构建） -->
            <LinearLayout
                android:id="@+id/boss_bone_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="4dp" />

            <!-- 魂核装备栏 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="━━━ 魂核装备 ━━━"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tv_soul_core_equipped"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:text="未装备魂核" />

            <LinearLayout
                android:id="@+id/soul_core_inventory"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="4dp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
